      { title: 'Dostupná psychologická pomoc', desc: 'Zajistíme dostupnost psychologů hrazených z pojištění a krizových center 24/7.' },
      { title: 'Prevence duševního zdraví ve školách', desc: 'Podpoříme školní programy prevence duševního zdraví a destigmatizační kampaně.' },
      { title: 'Hrazená antikoncepce', desc: 'Zajistíme cílené hrazení antikoncepce a dostupnost menstruačních pomůcek.' },
      { title: 'Dostupné interrupční služby', desc: 'Udržíme dostupnou síť interrupčních služeb a zakotvíme ústavní právo na interrupci.' },
      { title: 'Zákon o eutanazii', desc: 'Připravíme zákon o eutanazii s přísnými odbornými podmínkami a podporou rodiny.' },
