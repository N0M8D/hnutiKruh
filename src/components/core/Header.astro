---
import { Icon } from 'astro-icon/components'

interface NavItem {
  title: string;
  slug?: string;
  highlight?: boolean;
  children?: NavItem[];
}

interface Props {
  navData?: NavItem[];
  rightMenu?: boolean;
}

const { navData, rightMenu } = Astro.props as Props;
---

<script type="module">
  document.addEventListener('DOMContentLoaded', function() {
    const menuButton = document.querySelector('#menuButton')
    const navHeader = document.querySelector('#odysseyNavHeader');
    const menuButtonIconHam = document.querySelector('#menuButtonIconHam');
    const menuButtonIconClose = document.querySelector('#menuButtonIconClose');

    if (!menuButton || !navHeader || !menuButtonIconHam || !menuButtonIconClose) {
      console.error('Menu elements not found');
      return;
    }

    const dropdownItems = Array.from(navHeader.querySelectorAll('[data-nav-item]'));

    function closeDropdowns() {
      dropdownItems.forEach((item) => {
        item.removeAttribute('nav-dropdown-open');
        const trigger = item.querySelector('[data-nav-dropdown-trigger]');
        if (trigger) {
          trigger.setAttribute('aria-expanded', 'false');
        }
      });
    }

    menuButton.addEventListener('click', toggleMenu)

    dropdownItems.forEach((item) => {
      const trigger = item.querySelector('[data-nav-dropdown-trigger]');
      if (!trigger) {
        return;
      }

      trigger.addEventListener('click', (event) => {
        event.stopPropagation();
        const isOpen = item.hasAttribute('nav-dropdown-open');
        closeDropdowns();

        if (!isOpen) {
          item.setAttribute('nav-dropdown-open', '');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });

    document.addEventListener('click', (event) => {
      if (!navHeader.contains(event.target)) {
        closeDropdowns();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeDropdowns();
      }
    });

    function toggleMenu() {
      menuButtonIconHam.toggleAttribute('hidden');
      menuButtonIconClose.toggleAttribute('hidden');
      
      if (navHeader.hasAttribute('mobile-menu-open')) {
        menuButton.title = "Open Main Menu"
      } else {
        menuButton.title = "Close Main Menu"
      }
      
      closeDropdowns();
      navHeader.toggleAttribute('mobile-menu-open');
    }
  });
</script>  

<header id="odysseyNavHeader" class={`${rightMenu ? "header--right" : ``.trim()}`}>
  <div class="header-logo-menu__container">
  <button id="menuButton" title="Open Main Menu">
    <span id="menuButtonIconHam">
      <Icon name="ic:baseline-menu" width={24} height={24} />
    </span>
    <span id="menuButtonIconClose" hidden>
      <Icon name="ic:baseline-close" width={24} height={24} />
    </span>
  </button>
  <a class="header-logo__link" href="/">
    <slot name="logo">
    </slot>
  </a>
  </div>
  <div class="header-nav__container">
    <slot name="nav">
      {navData && <nav>
        <ul>
          {navData.map((navItem: NavItem, index: number) => (
            (<li data-nav-item class={navItem.children?.length ? 'nav-item nav-item--has-children' : 'nav-item'}>
              {navItem.children?.length ? (
                <>
                  <button
                    type="button"
                    class={navItem.highlight ? 'nav-trigger highlight-button' : 'nav-trigger'}
                    data-nav-dropdown-trigger
                    aria-expanded="false"
                    aria-controls={`nav-submenu-${index}`}
                  >
                    <span>{navItem.title}</span>
                    <Icon name="ic:baseline-keyboard-arrow-down" width={18} height={18} class="nav-trigger__icon" />
                  </button>
                  <div id={`nav-submenu-${index}`} class="nav-submenu">
                    {navItem.children.map((childItem: NavItem) => (
                      <a href={childItem.slug} class="nav-submenu__link">
                        {childItem.title}
                      </a>
                    ))}
                  </div>
                </>
              ) : (
                <a href={navItem.slug} class={navItem.highlight ? 'highlight-button' : ''}>
                  {navItem.title}
                </a>
              )}
            </li>)
          ))}
        </ul>
      </nav>}
    </slot>
  </div>
  <div class="header-action-item__container">
    <slot name="action-item">
    </slot>
  </div>
</header>

<style>
  header {
    width: 100%;
    padding: 0.45rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    /* Glassmorphism s teplou surface barvou */
    background: rgba(255, 248, 245, 0.85);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border-radius: 0;
    box-shadow: 0 2px 20px 0 rgba(37, 25, 15, 0.06);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  header.header--right {
    display: grid;
    grid-template-columns: 1fr auto auto;
  }
  .header-logo__link {
    width: fit-content;
    color: inherit;
    text-decoration: none;
    display: flex;
    align-items: center;
    line-height: 0;
  }
  .header-logo__link :global(.logo-img) {
    max-width: 170px;
    margin: 0;
  }
  .header-logo-menu__container {
    display: flex;
    align-items: center;
    z-index: 1000;
    position: relative;
  }
  .header-action-item__container {
    z-index: 1000;
    position: relative;
  }
  #menuButton {
    outline: none;
    border: none;
    background-color: transparent;
    margin-right: 0.5rem;
    display: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    color: var(--color-on-surface);
  }
  #menuButton > span {
    color: var(--color-on-surface);
    vertical-align: middle;
  }
  nav {
    display: flex;
  }
  nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: nowrap;
  }
  nav ul li a {
    font-family: var(--theme-font-family-label, 'Work Sans', sans-serif);
    font-weight: 500;
    font-size: 0.95rem;
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    color: var(--color-on-surface);
    opacity: 0.75;
    border-radius: 9999px;
    transition: opacity var(--theme-transition), background var(--theme-transition);
    white-space: nowrap;
  }
  .nav-trigger {
    font-family: var(--theme-font-family-label, 'Work Sans', sans-serif);
    font-weight: 500;
    font-size: 0.95rem;
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    color: var(--color-on-surface);
    opacity: 0.75;
    border-radius: 9999px;
    transition: opacity var(--theme-transition), background var(--theme-transition);
    white-space: nowrap;
    border: none;
    background: transparent;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
  }
  nav ul li a:hover,
  .nav-trigger:hover {
    opacity: 1;
    background: rgba(163, 59, 62, 0.07);
  }
  nav ul li a.highlight-button,
  .nav-trigger.highlight-button {
    background: var(--theme-gradient-primary, linear-gradient(135deg, #a33b3e 0%, #ff8080 100%));
    color: #ffffff;
    opacity: 1;
    padding: 0.5rem 1.25rem;
    box-shadow: 0 2px 12px 0 rgba(163, 59, 62, 0.20);
    transition: box-shadow var(--theme-transition), transform var(--theme-transition);
  }
  nav ul li a.highlight-button:hover,
  .nav-trigger.highlight-button:hover {
    box-shadow: 0 4px 20px 0 rgba(163, 59, 62, 0.30);
    transform: translateY(-1px);
    background: var(--theme-gradient-primary);
  }
  .nav-item {
    position: relative;
  }
  .nav-item--has-children[nav-dropdown-open] .nav-trigger__icon {
    transform: rotate(180deg);
  }
  .nav-trigger__icon {
    transition: transform var(--theme-transition);
  }
  .nav-submenu {
    position: absolute;
    top: calc(100% + 0.65rem);
    right: 0;
    min-width: 10rem;
    padding: 0.4rem;
    border-radius: 1rem;
    background: rgba(255, 248, 245, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 16px 40px rgba(37, 25, 15, 0.14);
    display: none;
    flex-direction: column;
    gap: 0.15rem;
  }
  .nav-item--has-children[nav-dropdown-open] .nav-submenu {
    display: flex;
  }
  .nav-submenu__link {
    font-family: var(--theme-font-family-label, 'Work Sans', sans-serif);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-on-surface);
    padding: 0.7rem 0.85rem;
    border-radius: 0.8rem;
    opacity: 0.92;
    white-space: nowrap;
    transition: background var(--theme-transition), opacity var(--theme-transition), transform var(--theme-transition);
  }
  .nav-submenu__link:hover {
    opacity: 1;
    background: rgba(163, 59, 62, 0.07);
    transform: translateY(-1px);
  }

  @media(max-width: 1120px) {
    nav {
      display: none;
    }
    #menuButton {
      display: block;
      z-index: 1000;
      position: relative;
    }
    .header-nav__container {
      width: 100%;
      background: rgba(255, 248, 245, 0.97);
      backdrop-filter: blur(20px);
      box-shadow: 0 8px 32px rgba(37, 25, 15, 0.10);
      display: none;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      z-index: 999;
      padding: 1rem 0;
    }
    header[mobile-menu-open] .header-nav__container {
      display: flex;
      pointer-events: auto;
    }
    header[mobile-menu-open] nav {
      display: flex;
      width: 100%;
    }
    header[mobile-menu-open] nav ul {
      flex-direction: column;
      width: 100%;
      padding: 0 1rem;
      gap: 0.25rem;
    }
    header[mobile-menu-open] nav ul li {
      width: 100%;
    }
    header[mobile-menu-open] nav ul li a,
    header[mobile-menu-open] nav ul li .nav-trigger {
      pointer-events: auto;
      cursor: pointer;
      color: var(--color-on-surface);
      opacity: 1;
      font-size: 1.05rem;
      padding: 0.9rem 1rem;
      border-radius: var(--theme-shape-radius);
      display: block;
      width: 100%;
      text-align: center;
    }
    header[mobile-menu-open] nav ul li .nav-trigger {
      display: flex;
      justify-content: center;
      gap: 0.35rem;
    }
    header[mobile-menu-open] nav ul li a:hover,
    header[mobile-menu-open] nav ul li .nav-trigger:hover {
      background: rgba(163, 59, 62, 0.07);
    }
    header[mobile-menu-open] nav ul li a.highlight-button,
    header[mobile-menu-open] nav ul li .nav-trigger.highlight-button {
      background: var(--theme-gradient-primary);
      color: white;
      margin-top: 0.5rem;
      box-shadow: 0 2px 12px 0 rgba(163, 59, 62, 0.20);
    }
    header[mobile-menu-open] nav ul li a.highlight-button:hover,
    header[mobile-menu-open] nav ul li .nav-trigger.highlight-button:hover {
      box-shadow: 0 4px 20px 0 rgba(163, 59, 62, 0.30);
    }
    .nav-submenu {
      position: static;
      min-width: 0;
      margin-top: 0.5rem;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      box-shadow: none;
      padding: 0;
    }
    .nav-submenu__link {
      width: 100%;
      text-align: center;
      padding: 0.8rem 1rem;
      border-radius: var(--theme-shape-radius);
      background: rgba(163, 59, 62, 0.05);
    }
  }
</style>