    cil: 'Dostupná, bezpečná a moderní doprava pro občany i podnikatele.',
    navrhy: [
      { title: 'Dokončení pražského okruhu', desc: 'Dokončíme pražský okruh a vystavíme 100 obchvatů obcí s nejvyšší tranzitní zátěží.' },
