---
import Layout from '../../layouts/Page.astro';
import ZapojSe from '../../components/sections/ZapojSe.astro';
import { Icon } from 'astro-icon/components';

const seo = {
  title: 'Program - Hnutí Kruh',
  description: 'Program Hnutí Kruh - naše hodnoty a vize pro férovou politiku',
};

const topics = [
  {
    id: 'socialni-politika',
    icon: 'ic:baseline-volunteer-activism',
    title: 'Sociální politika',
    vize: 'Sociální politika má být oporou, ne labyrintem byrokracie. Chceme důstojné mzdy pro pracující v sociálních službách, podporu pečujících a jistotu, že každý člověk bude mít šanci na stabilní a bezpečný život. Stavíme na principu solidarity, spravedlivého ohodnocení práce a respektu ke stáří i rodičovství.',
    cil: 'Společnost, kde péče a práce jsou náležitě oceněny a kde stát vytváří férové a dostupné podmínky pro všechny.',
    navrhy: [
      { title: 'Platy napojené na průměrnou mzdu', desc: 'Navážeme platy v sociálních a zdravotních službách na průměrnou mzdu s automatickou valorizací podle inflace.' },
      { title: 'Víceleté financování sociálních služeb', desc: 'Financování sociálních služeb plánovat víceleté, aby organizace nemusely přežívat z roku na rok.' },
      { title: 'Pětistupňový systém příspěvků na péči', desc: 'Zavedeme pětistupňový systém příspěvků na péči pro spravedlivější podporu podle reálných potřeb.' },
      { title: 'Dostupné odlehčovací služby', desc: 'Rozšíříme odlehčovací služby s jednoduchou online žádostí a garantovanou lhůtou vyřízení.' },
      { title: 'Důstojné a aktivní stáří', desc: 'Podpoříme aktivní stáří – kluby, mentoring, bezbariérové prostředí, mobilní asistenční týmy.' },
      { title: 'Férová mateřská a rodičovská', desc: 'Zajistíme důstojnou mateřskou a rodičovskou pro všechny rodiče, včetně OSVČ a možnosti souběžné péče obou pečujících.' },
      { title: 'Podpora náhradní rodinné péče', desc: 'Posílíme finanční a společenskou prestiž pěstounů a podpoříme náhradní rodinnou péči.' },
      { title: 'Zálohové výživné pro každé dítě', desc: 'Stát bude automaticky zajišťovat vyplácení, administrativu a vymáhání výživného, aby děti nedoplácely na nesolidní rodiče.' },
      { title: 'Základní příjem a menstruační volno', desc: 'Pilotujeme nepodmíněný základní příjem a zavedeme menstruační volno jako moderní sociální inovace.' },
      { title: 'Modernizace úřadů práce', desc: 'Modernizujeme úřady práce: osobní plány, práce na zkoušku, transparentní portál pracovních nabídek.' },
    ],
