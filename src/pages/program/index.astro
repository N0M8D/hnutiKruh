  {
    id: 'lidska-prava',
    icon: 'ic:baseline-balance',
    title: 'Lidská práva',
    vize: 'Chceme společnost postavenou na spravedlnosti, spolupráci a respektu. Každý má mít šanci uspět, nikdo nemá trpět kvůli svému původu či postavení. Odmítáme koncentraci moci v rukou vyvolených – rozhodovat musíme společně.',
    cil: 'Zajistit rovnost a ochranu základních práv, včetně reprodukčních, dětských a občanských, a garantovat důstojnost pro všechny.',
    navrhy: [
      { title: 'Férový daňový systém', desc: 'Zavedeme daňový systém, kde se daní astronomické zisky, ne práce běžných lidí.' },
      { title: 'Participativní demokracie', desc: 'Zapojíme veřejnost do spolurozhodování – hlasovací lístky k referendům přímo do schránek a zákon o občanských shromážděních.' },
      { title: 'Rovná hlasovací práva', desc: 'Posílíme rovná hlasovací práva, např. doplněním braillova písma na hlasovací lístky.' },
      { title: 'Ústavní právo na interrupci', desc: 'Zavedeme vyšší právní ochranu interrupcí, zakotvíme je do ústavy a zařadíme mezi základní zdravotní péči.' },
      { title: 'Dostupné menstruační pomůcky', desc: 'Zajistíme dostupnost menstruačních pomůcek ve veřejných budovách.' },
