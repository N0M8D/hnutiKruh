---
// File: src/components/sections/Lide.astro

export interface Props {
  people?: {
    name: string;
    role?: string;
    description?: string;
    photo?: string;
    href?: string;
  }[];
  joinHref?: string;
  count?: number;
}

const { people = [], joinHref = '/people', count = 5 } = Astro.props;

// Fisher-Yates shuffle (server-side → náhodné pořadí při každém renderu)
function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const displayed = shuffle(people).slice(0, count);
---

<section class="lide-sec" id="lide">
  <div class="lide-header">
    <h2 class="lide-heading">Naše Tváře</h2>
    <a class="lide-all-link" href='/people'>Všechny tváře &rarr;</a>
  </div>

  <div class="lide-row">
    {displayed.map((person) => (
      <a class="avatar-card" href={person.href ?? joinHref}>
        <div class="avatar-wrap">
          {person.photo
            ? <img src={person.photo} alt={`Fotka ${person.name}`} class="avatar-img" />
            : <span class="avatar-placeholder">{person.name.charAt(0)}</span>
          }
        </div>
        <span class="avatar-name">{person.name}</span>
        {(person.role ?? person.description) && (
          <span class="avatar-role">{person.role ?? person.description}</span>
        )}
      </a>
    ))}

    <!-- CTA card -->
    <a class="avatar-card cta-card" href={joinHref}>
      <div class="avatar-wrap cta-wrap">
        <span class="cta-plus">+</span>
      </div>
      <span class="avatar-name">Vy?</span>
      <span class="avatar-role">Přidejte se</span>
    </a>
  </div>
</section>

<style>
  .lide-sec {
    padding: 3.5rem 1.5rem;
    text-align: center;
    max-width: var(--container-max-width, 1100px);
    margin: 0 auto;
  }

  .lide-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  .lide-heading {
    font-family: var(--theme-font-family-headline, 'Manrope', sans-serif);
    font-size: var(--font-size-xl, 2rem);
    font-weight: 800;
    color: var(--color-on-surface, #1f1b1b);
    margin: 0;
  }

  .lide-all-link {
    font-family: var(--theme-font-family-label, 'Work Sans', sans-serif);
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-primary, #ff8080);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .lide-all-link:hover {
    opacity: 0.75;
  }

  /* ── Row ──────────────────────────────────────── */
  .lide-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem 2rem;
    max-width: 1100px;
    margin: 3.5rem auto 0;
  }

  /* ── Avatar card ──────────────────────────────── */
  .avatar-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    text-decoration: none;
    color: inherit;
    width: 130px;
    transition: transform 0.18s;
  }

  .avatar-card:hover {
    transform: translateY(-3px);
  }

  /* ── Avatar circle ───────────────────────────── */
  .avatar-wrap {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    background: #f5e6d8;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0 !important;
    box-shadow: none !important;
  }

  .avatar-placeholder {
    font-size: 2rem;
    font-weight: 700;
    color: #c87b5a;
  }

  /* ── Text ─────────────────────────────────────── */
  .avatar-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-on-surface, #1f1b1b);
    line-height: 1.2;
  }

  .avatar-role {
    font-size: 0.75rem;
    color: var(--color-on-surface-variant, #7a6360);
    line-height: 1.2;
  }

  /* ── CTA card ─────────────────────────────────── */
  .cta-wrap {
    background: #f5e6d8;
    border: 2px dashed #e5c9b8;
  }

  .cta-plus {
    font-size: 2rem;
    font-weight: 300;
    color: #c87b5a;
    line-height: 1;
    user-select: none;
  }

  .cta-card .avatar-name {
    color: var(--color-on-surface-variant, #7a6360);
    font-weight: 600;
  }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 480px) {
    .lide-row {
      gap: 1.25rem 1.5rem;
    }
    .avatar-wrap {
      width: 90px;
      height: 90px;
    }
    .avatar-card {
      width: 100px;
    }
  }
</style>
