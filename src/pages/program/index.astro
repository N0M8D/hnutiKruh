  .program-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  /* ─── Left nav ─────────────────────────────────── */
  .program-nav {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    position: sticky;
    top: 5rem;
    background: var(--color-surface-lowest, #fff);
