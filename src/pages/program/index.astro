    padding: 0.5rem;
    box-shadow: 0 1px 6px rgba(0,0,0,0.07);
  }

  .program-nav__item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.75rem;
    border-radius: 1.5rem;
    border: none;
    background: transparent;
    cursor: pointer;
    text-align: left;
    font-size: 0.88rem;
    font-family: inherit;
    color: var(--color-text, #222);
    transition: background 0.15s, color 0.15s;
