---
/**
 * Hero – hlavní hero sekce
 *
 * Props:
 *   eyebrow?       – malý popis nad nadpisem (default: "Vize pro Česko")
 *   titleBefore?   – text před zvýrazněnou částí
 *   titleAccent?   – zvýrazněná část nadpisu (primary barva)
 *   titleAfter?    – text za zvýrazněnou částí
 *   description?   – popis pod nadpisem
 *   primaryHref?   – odkaz primárního tlačítka
 *   primaryLabel?  – text primárního tlačítka
 *   secondaryHref? – odkaz sekundárního tlačítka
 *   secondaryLabel?– text sekundárního tlačítka
 *   imageSrc?      – cesta k obrázku v pravém bloku
 *   imageAlt?      – alt text obrázku
 *   imageCaption?  – popisek přes obrázek (dole)
 */
const {
  eyebrow = 'Vize pro Česko',
  titleBefore = 'Měníme politiku',
  titleAccent = 'k lepšímu.',
  titleAfter = 'Společně.',
  description = 'Hnutí Kruh je otevřená platforma pro všechny, kteří věří v profesionální, transparentní a empatickou správu naší země. Jsme hlasem nové generace lídrů.',
  primaryHref = '/program',
  primaryLabel = 'Náš program',
  secondaryHref = '/organisation',
  secondaryLabel = 'Více o nás',
  imageSrc = '/assets/brand/hero_img.jpg',
  imageAlt = 'Hnutí Kruh',
  imageCaption = 'Společně tvoříme budoucnost.',
} = Astro.props;
---

<section class="hero">
  <div class="hero__inner">

    <!-- Levý panel: text -->
    <div class="hero__left">
      {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
      <h1 class="hero__title">
        {titleBefore && <span>{titleBefore}<br /></span>}
        {titleAccent && <span class="hero__accent">{titleAccent}</span>}
        {titleAfter && <span> {titleAfter}</span>}
      </h1>
      {description && <p class="hero__desc">{description}</p>}
      <div class="hero__actions">
        <a class="hero__btn hero__btn--primary" href={primaryHref}>{primaryLabel}</a>
      </div>
    </div>

    <!-- Pravý panel: obrázková karta -->
    <div class="hero__right">
      <div class="hero__img-card">
        <img src={imageSrc} alt={imageAlt} class="hero__img" />
        {imageCaption && (
          <div class="hero__img-caption">{imageCaption}</div>
        )}
      </div>
    </div>

  </div>
</section>

<style>
.hero {
  padding: 5rem 1.5rem 4rem;
}

.hero__inner {
  max-width: var(--container-max-width, 1100px);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

/* ── Levý panel ── */
.hero__eyebrow {
  font-family: var(--theme-font-family-label, 'Work Sans', sans-serif);
  font-size: var(--font-size-sm, 0.875rem);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-on-surface-variant, #564241);
  margin: 0 0 1rem 0;
}

.hero__title {
  font-family: var(--theme-font-family-headline, 'Manrope', sans-serif);
  font-size: clamp(2.4rem, 5vw, 4rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: var(--color-on-surface, #1f1b1b);
  margin: 0 0 1.5rem 0;
  text-align: left;
}

.hero__accent {
  color: var(--color-primary, #ff8080);
}

.hero__desc {
  font-size: var(--font-size-base, 1rem);
  color: var(--color-on-surface-variant, #564241);
  line-height: 1.65;
  max-width: 42ch;
  margin: 0 0 2.5rem 0;
}

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  align-items: center;
}

/* Tlačítka — inline, bez Button komponenty, aby nebyla závislost */
.hero__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.85rem 2rem;
  font-family: var(--theme-font-family-label, 'Work Sans', sans-serif);
  font-size: var(--font-size-base, 1rem);
  font-weight: 600;
  letter-spacing: 0.01em;
  line-height: 1;
  border-radius: var(--theme-button-border-radius, 9999px);
  text-decoration: none;
  transition: box-shadow var(--theme-transition), transform var(--theme-transition);
  cursor: pointer;
}

.hero__btn--primary {
  background: var(--theme-gradient-primary, linear-gradient(135deg, #ff8080 0%, #ffb3b1 100%));
  color: #ffffff;
  box-shadow: 0 4px 20px 0 rgba(255, 128, 128, 0.30);
}

.hero__btn--primary:hover {
  box-shadow: 0 6px 28px 0 rgba(255, 128, 128, 0.45);
  transform: translateY(-1px);
}

.hero__btn--secondary {
  background: var(--color-surface-highest, #e9e0e0);
  color: var(--color-on-surface, #1f1b1b);
}

.hero__btn--secondary:hover {
  background: var(--color-surface-dim, #e1d8d7);
  transform: translateY(-1px);
}

/* ── Pravý panel ── */
.hero__img-card {
  position: relative;
  border-radius: var(--theme-card-radius, 2rem);
  overflow: hidden;
  background: #1a1d1e;
  box-shadow: var(--g-shadow-raised, 0 20px 60px 0 rgba(37, 25, 15, 0.12));
  aspect-ratio: 4 / 5;
  max-width: 480px;
  margin-left: auto;
}

.hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  margin: 0;
  border-radius: 0;
  box-shadow: none;
}

.hero__img-caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 1rem 1.5rem;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
  color: #ffffff;
  font-family: var(--theme-font-family-label, 'Work Sans', sans-serif);
  font-size: var(--font-size-sm, 0.875rem);
  font-weight: 500;
  letter-spacing: 0.01em;
}

/* ── Responzivní ── */
@media (max-width: 900px) {
  .hero {
    padding: 3rem 1.5rem 2.5rem;
  }

  .hero__inner {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .hero__title {
    font-size: clamp(2rem, 8vw, 2.8rem);
  }

  .hero__img-card {
    max-width: 100%;
    margin: 0;
    aspect-ratio: 16 / 9;
  }
}
</style>
