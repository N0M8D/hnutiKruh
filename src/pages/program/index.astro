    title: 'Bezpečnost',
    vize: 'Bezpečnost chápeme jako komplexní službu, která dává lidem klid, ochranu a důvěru v budoucnost. Stavíme na prevenci kriminality, evropské spolupráci, moderní armádě i kybernetické bezpečnosti.',
    cil: 'Bezpečná společnost s profesionální armádou, důvěryhodnou policií a ochranou dat.',
    navrhy: [
      { title: 'Prevence kriminality', desc: 'Podpoříme prevenci kriminality – rekvalifikace, mentoring, mikropůjčky.' },
      { title: 'Evropská bezpečnostní spolupráce', desc: 'Rozvíjíme evropskou a sousedskou spolupráci při krizových situacích.' },
      { title: 'Profesionální armáda a zálohy', desc: 'Udržíme profesionální armádu a posílíme dobrovolné zálohy.' },
