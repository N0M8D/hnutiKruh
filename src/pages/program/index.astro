  {
    id: 'bydleni',
    icon: 'ic:baseline-home',
    title: 'Bydlení',
    vize: 'Důstojné bydlení je základní podmínkou pro spokojený život. Chceme ukončit obchod s chudobou a rozvíjet dostupné nájemní i sociální bydlení. Podporujeme koncept Housing First a férovou bytovou politiku, která chrání rodiny před pádem do bezdomovectví.',
    cil: 'Stabilní a dostupné bydlení pro všechny, zejména zranitelné skupiny.',
    navrhy: [
      { title: 'Obecní bytový fond', desc: 'Intenzivně podpoříme růst obecního bytového fondu prostřednictvím státních grantů a bezúročných půjček obcím.' },
      { title: 'Zdanění prázdných bytů', desc: 'Zvýšíme zdanění dlouhodobě neobsazených bytů a komerčních prostor, aby se motivovalo k jejich využití.' },
      { title: 'Zákon o družstevním bydlení', desc: 'Zavedeme moderní zákon o družstevním bydlení jako podmínku pro rozvoj obcí a návrat důvěry ve společnost.' },
      { title: 'Komunitní centra a sousedské iniciativy', desc: 'Podpoříme komunitní centra a sousedské iniciativy pro začleňování ohrožených skupin.' },
      { title: 'Kapacity azylových domů', desc: 'Rozšíříme kapacity azylových domů a nízkoprahových ubytoven.' },
      { title: 'Housing First', desc: 'Podpoříme vznik 5 000 nízkoprahových bytů v režimu Housing First.' },
