---
import Layout from '../../layouts/Page.astro';
import ZapojSe from '../../components/sections/ZapojSe.astro';

// Import all person profiles
const peopleModules = import.meta.glob('../../pages/people/people-list/*.mdx', { eager: true });

// Convert to usable array of person objects
const allPeople = Object.values(peopleModules).map((mod: any) => ({
  name: mod.frontmatter.name,
  description: mod.frontmatter.description,
  photo: mod.frontmatter.featuredImage,
  href: mod.url,
  role: mod.frontmatter.role,
  // Add slug to help with filtering
  slug: mod.url.split('/').pop()
}));

// Define lists of people by their slugs (MDX filenames without extension)
const boardMembers = [
  'marta-martinova',
  'michaela-nedory',
  'klara-kadar',
  'pavla-krausova',
];

// Shuffle boardMembers on each page load
function shuffle(array) {
  for (let i = array.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
  }
  return array;
}
shuffle(boardMembers);

// Filter people into different groups
const predsednictvoUnsorted = allPeople.filter(person => boardMembers.includes(person.slug));
// Sort predsednictvo according to shuffled boardMembers order
const predsednictvo = boardMembers.map(slug => predsednictvoUnsorted.find(person => person.slug === slug));

const seo = {
  title: 'Naše tváře | Hnutí kruh',
  description: 'Seznamte se s tvářemi Hnutí kruh',
};
---

<Layout {seo}>
  <section class="people-page">
    <div class="people-page__inner">

      <header class="people-header">
        <h1>Naše tváře</h1>
        <div class="people-header__accent"></div>
        <p class="people-header__lead">Seznamte se s lidmi, kteří stojí za Hnutím Kruh.</p>
      </header>

    <section class="people-section">

      
      <!-- Předsednictvo Section -->
      <div class="people-category">
        <h2>Předsednictvo</h2>
        <div class="people-grid">
          {predsednictvo.map((person, index) => {
            const frameImage = index % 2 === 0 ? '/assets/brand/kolo+.png' : '/assets/brand/kolo.png';
            return (
              <a href={person.href} class="person-card">
                <div class="photo-wrapper">
                  <img src={frameImage} alt="" class="photo-frame noShadow" />
                  <img src={person.photo} alt={person.name} class="person-photo noShadow" />
                </div>
                <h3>{person.name}</h3>
                <p class="role">{person.role}</p>
                <p class="description">{person.description}</p>
              </a>
            );
          })}
        </div>
      </div>
      
      <!-- Další tváře Section -->
      <div class="people-category">
        <h2>Další tváře</h2>
        <div class="people-grid">
          {allPeople
        .filter(person => !boardMembers.includes(person.slug))
        .map((person, index) => {
          const frameImage = index % 2 === 0 ? '/assets/brand/kolo+.png' : '/assets/brand/kolo.png';
          return (
            <a href={person.href} class="person-card">
          <div class="photo-wrapper">
            <img src={frameImage} alt="" class="photo-frame noShadow" />
            <img src={person.photo} alt={person.name} class="person-photo noShadow" />
          </div>
          <h3>{person.name}</h3>
          <p class="role">{person.role}</p>
          <p class="description">{person.description}</p>
            </a>
          );
        })}
        </div>
      </div>
      
    </section>
    </div>
  </section>
  <ZapojSe />
</Layout>
  
<style>
/* Page wrapper */
.people-page {
  padding: 4rem 1.5rem;
}

.people-page__inner {
  max-width: var(--container-max-width, 1100px);
  margin: 0 auto;
}

/* Header */
.people-header {
  text-align: center;
  margin-bottom: 3.5rem;
}

.people-header h1 {
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  margin-bottom: 0.5rem;
}

.people-header__accent {
  width: 3rem;
  height: 4px;
  background: var(--color-primary);
  border-radius: 2px;
  margin: 0.75rem auto 1.25rem;
}

.people-header__lead {
  color: var(--color-text-muted, #555);
  font-size: 1.05rem;
}

/* Sections */
.people-section {
  text-align: center;
}

.people-category {
  margin-bottom: 4rem;
}

.people-category h2 {
  margin-bottom: 1.5rem;
  font-size: 1.5rem;
}

/* Grid */
.people-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.25rem;
  margin-top: 1rem;
}

/* Cards — sjednoceno s manifest boxy */
.person-card {
  background: var(--color-surface-lowest, #ffffff);
  padding: 1.5rem 1rem;
  border-radius: var(--theme-card-radius, 2rem);
  text-decoration: none;
  color: inherit;
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.07);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.person-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.11);
}

/* Photo */
.photo-wrapper {
  position: relative;
  width: 120px;
  height: 120px;
  margin: 0 auto 1rem;
}

.photo-frame {
  position: absolute;
  top: 0;
  left: 0;
  width: 120px;
  height: 120px;
  z-index: 1;
  max-width: 100%;
}

.person-photo {
  position: absolute;
  top: 14%;
  left: 14%;
  width: 72%;
  height: 72%;
  object-fit: cover;
  border-radius: 50%;
  z-index: 2;
  max-width: 100%;
}

.role {
  font-weight: bold;
  margin: 0.25rem 0;
  font-size: 0.9rem;
  color: var(--color-primary);
}

.description {
  font-size: 0.85rem;
  line-height: 1.45;
  color: var(--color-text-muted, #666);
  margin: 0.25rem 0 0;
}

/* Responsive */
@media (max-width: 560px) {
  .people-page {
    padding: 2.5rem 1rem;
  }

  .people-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>
