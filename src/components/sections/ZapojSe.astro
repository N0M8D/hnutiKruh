---
import { Icon } from 'astro-icon/components';
import Button from '../buttons/Button.astro';
import FormInput from '../form-fields/FormInput.astro';
import FormCheckbox from '../form-fields/FormCheckbox.astro';

/**
 * ZapojSe – sekce "zapoj se do kruhu"
 *
 * Props:
 *   title?        – hlavní nadpis (HTML string, výchozí níže)
 *   items?        – pole { icon, title, description, href, linkLabel } – možnosti zapojení
 */

const {
  title = `Buďte součástí&nbsp;kruhu.<br>Změna začíná <span class="zapoj-headline__accent">u&nbsp;vás</span>.`,
  items = [
    {
      icon: 'ic:baseline-favorite',
      iconColor: 'var(--color-primary, #ff8080)',
      title: 'Finanční podpora',
      description: 'Vaše dary nám umožňují vést kampaň nezávisle na velkých sponzorech.',
      href: '/forms/daruj',
      linkLabel: 'Podpořte nás darem',
    },
    {
      icon: 'ic:baseline-people',
      iconColor: 'var(--color-secondary, #22686c)',
      title: 'Zapojte se jako dobrovolník nebo se staň členkou/členem',
      description: 'Hledáme nadšené lidi, expertky a experty i další nadšence nebo aktivistky a aktivisty, kteří nám pomohou s kontaktní kampaní v regionech.',
      href: '/forms/joinus',
      linkLabel: 'Chci se zapojit',
    },
    /*{
      icon: 'ic:baseline-campaign',
      iconColor: 'var(--color-tertiary, #795900)',
      title: 'Sledujte náš program',
      description: 'Přečtěte si, za co bojujeme a co chceme prosadit pro rodiny a pečující.',
      href: '/program',
      linkLabel: 'Náš program',
    },*/
  ],
} = Astro.props;
---

<section class="zapoj-se">
  <div class="zapoj-se__inner">

    <!-- Levý sloupeček: nadpis + možnosti zapojení -->
    <div class="zapoj-se__left">
      <h2 class="zapoj-headline" set:html={title} />

      <ul class="zapoj-items">
        {items.map((item) => (
          <li class="zapoj-item">
            <div class="zapoj-item__icon" style={`--icon-color: ${item.iconColor}`}>
              <Icon name={item.icon} width={22} height={22} />
            </div>
            <div class="zapoj-item__body">
              <strong class="zapoj-item__title">{item.title}</strong>
              <p class="zapoj-item__desc">{item.description}</p>
              <a class="zapoj-item__link" href={item.href}>
                {item.linkLabel}
                <Icon name="ic:baseline-arrow-forward" width={16} height={16} class="zapoj-item__arrow" />
              </a>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <!-- Pravý sloupeček: newsletter karta -->
    <div class="zapoj-se__right">
      <div class="nl-card">
        <p class="nl-card__eyebrow">Newsletter</p>
        <h3 class="nl-card__title">Odebírejte náš newsletter</h3>
        <p class="nl-card__desc">
          Získejte exkluzivní informace o naší kampani, kandidátkách a akcích ve vašem okolí přímo do e-mailu.
        </p>

        <form name="Newsletter Form" method="POST" action="/api/subscribe" class="nl-form">
          <div class="nl-form__two-col">
            <FormInput name="Jmeno" label="Jméno" />
            <FormInput name="Prijmeni" label="Příjmení" />
          </div>
          <FormInput name="Email" label="E-mail" type="email" required />
          <div class="nl-btn-wrap">
            <Button fullWidth>Přihlásit k odběru</Button>
          </div>
          <FormCheckbox
            name="consent"
            required={true}
            labelHtml="Souhlasím se <a href='/organisation/legal' target='_blank' rel='noopener'>zpracováním osobních údajů</a> a zasíláním newsletteru"
          />
        </form>
      </div>
    </div>

  </div>
</section>

<style>
/* ── Sekce ── */
.zapoj-se {
  padding: 5rem 2rem;
}

.zapoj-se__inner {
  max-width: var(--container-max-width, 1100px);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

/* ── Levý panel ── */
.zapoj-headline {
  font-family: var(--theme-font-family-headline, 'Manrope', sans-serif);
  font-size: var(--font-size-xxl, 2.5rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: var(--color-on-surface, #1f1b1b);
  margin: 0 0 2.5rem 0;
  text-align: left;
}

.zapoj-headline :global(.zapoj-headline__accent) {
  color: var(--color-primary, #ff8080);
}

.zapoj-items {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 1.75rem;
}

.zapoj-item {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}

.zapoj-item__icon {
  flex-shrink: 0;
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 9999px;
  background: color-mix(in srgb, var(--icon-color) 15%, transparent);
  color: var(--icon-color);
  display: flex;
  align-items: center;
  justify-content: center;
}

.zapoj-item__body {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.zapoj-item__title {
  font-family: var(--theme-font-family-headline, 'Manrope', sans-serif);
  font-size: var(--font-size-base, 1rem);
  font-weight: 700;
  color: var(--color-on-surface, #1f1b1b);
}

.zapoj-item__desc {
  font-size: var(--font-size-sm, 0.875rem);
  color: var(--color-on-surface-variant, #564241);
  margin: 0;
  line-height: 1.5;
}

.zapoj-item__link {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-family: var(--theme-font-family-label, 'Work Sans', sans-serif);
  font-size: var(--font-size-sm, 0.875rem);
  font-weight: 600;
  color: var(--color-primary, #ff8080);
  text-decoration: none;
  margin-top: 0.15rem;
  transition: gap var(--theme-transition, 0.2s ease-in-out);
}

.zapoj-item__link:hover {
  gap: 0.5rem;
}

/* ── Newsletter karta ── */
.nl-card {
  background: var(--color-surface-lowest, #ffffff);
  border-radius: var(--theme-card-radius, 2rem);
  padding: 2.5rem;
  box-shadow: var(--g-shadow-raised, 0 20px 60px 0 rgba(37, 25, 15, 0.08));
}

.nl-card__eyebrow {
  font-family: var(--theme-font-family-label, 'Work Sans', sans-serif);
  font-size: var(--font-size-sm, 0.875rem);
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-primary, #ff8080);
  margin: 0 0 0.5rem 0;
}

.nl-card__title {
  font-size: var(--font-size-lg, 1.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin: 0 0 0.75rem 0;
  text-align: left;
}

.nl-card__desc {
  font-size: var(--font-size-sm, 0.875rem);
  color: var(--color-on-surface-variant, #564241);
  line-height: 1.55;
  margin: 0 0 1.5rem 0;
}

/* Formulář */
.nl-form {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.nl-form__two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 0.75rem;
}

/* Tlačítko zarovnané na spodek sloupce (bez labelu) */
.nl-btn-wrap {
  margin-top: 0.25rem;
}

/* ── Responzivní ── */
@media (max-width: 900px) {
  .zapoj-se__inner {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .zapoj-headline {
    font-size: var(--font-size-xl, 2rem);
  }
}
</style>
