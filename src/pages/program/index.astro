      { title: 'Prevence rizikového chování', desc: 'Podpoříme prevenci rizikového chování se zaměřením na duševní zdraví.' },
      { title: 'Omezení reklamy na alkohol', desc: 'Omezíme reklamu na alkohol podobně jako u tabáku.' },
      { title: 'Regulace psychoaktivních látek', desc: 'Postupně legalizujeme a regulujeme psychoaktivní látky podle jejich rizikovosti.' },
      { title: 'Adiktologické služby', desc: 'Ukotvíme adiktologické služby na pomezí zdravotnictví a sociální péče.' },
      { title: 'Nízkoprahová zařízení', desc: 'Podpoříme vznik nízkoprahových zařízení i pro uživatele alkoholu.' },
