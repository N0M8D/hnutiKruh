    cil: 'Zajistit rovný přístup ke vzdělání, podporu učitelů a moderní vzdělávací systém nezávislý na politických náladách.',
    navrhy: [
      { title: 'Rovný přístup ke vzdělání', desc: 'Garantujeme rovný přístup ke vzdělání bez ohledu na původ, příjem či zdravotní stav.' },
      { title: 'Dostupné školky a předškolní péče', desc: 'Zajistíme dostupné školky a předškolní péči, aby všechny děti měly rovný start.' },
      { title: 'Školy jako centra komunity', desc: 'Podpoříme venkovské a regionální školy jako centra komunitního života.' },
      { title: 'Důstojné platy učitelů', desc: 'Zajistíme důstojné platy učitelů a jasný kariérní řád.' },
      { title: 'Profesní rozvoj pedagogů', desc: 'Rozvíjíme profesní komunity učitelů, mentoring a sdílení dobré praxe.' },
      { title: 'Moderní kurikulum', desc: 'Pravidelně revidujeme kurikulum, doplníme digitální, finanční a vztahovou výchovu.' },
      { title: 'Školní psychologové', desc: 'Podpoříme školní psychology a krizové interventy, aby školy zvládaly náročné situace.' },
