---

<Layout {seo}>
  <section class="program-page">
    <div class="program-page__inner">

      <!-- Page header -->
      <header class="program-header">
        <div class="program-header__left">
          <p class="program-header__label">Vize pro Česko</p>
          <h1>Naše priority.</h1>
        </div>
        <div class="program-header__right">
          <p>Deset pilířů, které tvoří pevný kruh naší budoucnosti. Program postavený na lidskosti, odbornosti a odvaze měnit věci k lepšímu.</p>
        </div>
      </header>

      <!-- Sidebar + content -->
      <div class="program-layout">

        <!-- Left nav -->
        <nav class="program-nav" aria-label="Oblasti programu">
          {topics.map((t, i) => (
            <button
              class={`program-nav__item${i === 0 ? ' is-active' : ''}`}
              data-topic={t.id}
              type="button"
            >
              <span class="program-nav__icon">
                <Icon name={t.icon} width={18} height={18} />
              </span>
              <span class="program-nav__label">{t.title}</span>
              <span class="program-nav__arrow">
                <Icon name="ic:baseline-chevron-right" width={18} height={18} />
              </span>
            </button>
          ))}
        </nav>

        <!-- Right content panels -->
        <div class="program-content">
          {topics.map((t, i) => (
            <div class={`program-panel${i === 0 ? ' is-active' : ''}`} data-panel={t.id}>

              <div class="program-panel__header">
                <span class="program-panel__icon">
                  <Icon name={t.icon} width={28} height={28} />
                </span>
                <h2>{t.title}</h2>
              </div>

              <div class="program-panel__meta">
                <div class="program-panel__vize">
                  <p class="meta-label">— Naše vize</p>
                  "{t.vize}"
                </div>
                <div class="program-panel__cil">
                  <p class="meta-label">Cíl</p>
                  <p>{t.cil}</p>
                </div>
              </div>

              <h3 class="program-panel__proposals-title">Co navrhujeme</h3>
              <ol class="program-panel__list">
                {t.navrhy.map((n, idx) => (
                  <li>
                    <span class="item-num">{String(idx + 1).padStart(2, '0')}</span>
                    <div class="item-body">
                      <strong class="item-title">{n.title}</strong>
                      <span class="item-desc">{n.desc}</span>
                    </div>
                  </li>
                ))}
              </ol>

            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
  <ZapojSe />
</Layout>

<style>
