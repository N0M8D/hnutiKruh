---
/**
 * SenatHero.astro
 * HERO sekce pro stránku senátních voleb 2026.
 * Kandidátky se zobrazují jako odkládací balíček karet, který se cyklicky proměňuje.
 */

interface Kandidatka {
  slug: string;
  jmeno: string;
  obvod: string;
  oblastExpertizy: string;
  foto: string;
  href: string;
  citace: string;
}

interface Props {
  kandidatky: Kandidatka[];
}

const { kandidatky } = Astro.props;
const jsonData = JSON.stringify(kandidatky);
const hasMultipleCandidates = kandidatky.length > 1;
---

<section class="senat-hero">
  <div class="senat-hero__claim">
    <span class="senat-hero__claim-text">Tady jsme.</span>
    <span class="senat-hero__claim-accent">Senátorky 2026</span>
  </div>

  <div class="senat-hero__inner">
    <div class="senat-hero__text">
      <p class="senat-hero__badge">Senátní volby 2026</p>
      <h1 class="senat-hero__title">Ženský hlas<br />mění pravidla<br />v Senátu</h1>
      <p class="senat-hero__desc">
        Do Senátu posíláme ženy, které spojují odbornost, zkušenost z praxe a
        osobní zodpovědnost. Naše kandidátky chtějí vrátit do politiky klid,
        důvěryhodnost a rozhodnutí, která obstojí nejen dnes, ale i v dalších
        letech. Senát má být pojistkou stability a rozumu pro celou zemi.
      </p>
      <div class="senat-hero__btns">
        <a href="#kandidatky" class="btn-primary">Poznej naše kandidátky</a>
        <a href="/program" class="btn-outline">Náš program</a>
      </div>
    </div>

    <div class="senat-hero__visual">
      <div class="hero-stack" id="heroStack">
        {kandidatky.map((k, i) => (
          <a
            href={k.href}
            class="hero-stack__card"
            data-index={i}
            data-state={i === 0 ? 'active' : i === 1 ? 'next' : 'hidden'}
            aria-hidden={i > 1}
            style={`--stack-angle: ${i % 2 === 0 ? '-6deg' : '6deg'};`}
          >
            <div class="hero-stack__photo-wrap">
              <img
                src={k.foto}
                alt={`Foto ${k.jmeno}`}
                class="hero-stack__photo"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
              <div class="hero-stack__photo-gradient" />
            </div>
            <div class="hero-stack__content">
              <span class="hero-stack__obvod">{k.obvod}</span>
              <strong class="hero-stack__name">{k.jmeno}</strong>
              <span class="hero-stack__expertiza">{k.oblastExpertizy}</span>
              <p class="hero-stack__quote">„{k.citace}"</p>
              <span class="hero-stack__link">Detail kandidátky →</span>
            </div>
          </a>
        ))}
      </div>

      {hasMultipleCandidates && (
        <div class="hero-dots" role="tablist" aria-label="Výběr kandidátky">
          {kandidatky.map((k, i) => (
            <button
              class={`hero-dot ${i === 0 ? 'hero-dot--active' : ''}`}
              data-target={i}
              role="tab"
              aria-selected={i === 0}
              aria-label={k.jmeno}
            />
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<script define:vars={{ jsonData }}>
  const kandidatky = JSON.parse(jsonData);
  const cards = document.querySelectorAll('.hero-stack__card');
  const dots = document.querySelectorAll('.hero-dot');
  let current = 0;
  let timer;

  function getState(index) {
    if (index === current) return 'active';

    const offset = (index - current + cards.length) % cards.length;
    if (offset === 1) return 'next';
    return 'hidden';
  }

  function applyState() {
    cards.forEach((card, index) => {
      const state = getState(index);
      card.dataset.state = state;
      card.setAttribute('aria-hidden', state === 'hidden' ? 'true' : 'false');
    });

    dots.forEach((dot, index) => {
      const isActive = index === current;
      dot.classList.toggle('hero-dot--active', isActive);
      dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
  }

  function goTo(index) {
    current = (index + cards.length) % cards.length;
    applyState();
  }

  function startAuto() {
    if (cards.length <= 1) return;
    timer = setInterval(() => goTo(current + 1), 5000);
  }

  function resetAuto() {
    clearInterval(timer);
    startAuto();
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      goTo(parseInt(dot.dataset.target, 10));
      resetAuto();
    });
  });

  applyState();
  startAuto();
</script>

<style>
  .senat-hero {
    --camp-dark:    #110c0a;
    --camp-gold:    #E3B754;
    --camp-akcent:  #C0392B;
    --camp-broskev: #FFE6D5;
    --camp-cream:   #FFF8F5;
  }

  .senat-hero__claim {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 2.5rem 1.5rem 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4em;
  }

  .senat-hero__claim-text,
  .senat-hero__claim-accent {
    font-family: var(--theme-font-family-headline);
    font-size: clamp(2.25rem, 5.5vw, 5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .senat-hero__claim-text {
    color: var(--camp-cream);
  }

  .senat-hero__claim-accent {
    color: var(--camp-gold);
  }

  .senat-hero {
    background: var(--camp-dark);
    padding: 3rem clamp(1.5rem, 4vw, 3rem) 4rem;
    min-height: min(50rem, calc(100svh - 4.5rem));
    display: flex;
    flex-direction: column;
  }

  .senat-hero__inner {
    max-width: var(--container-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 28rem);
    gap: 3rem;
    align-items: center;
    min-height: clamp(34rem, 66vh, 48rem);
    flex: 1;
  }

  .senat-hero__badge {
    display: inline-block;
    background: var(--camp-gold);
    color: var(--camp-dark);
    font-family: var(--theme-font-family-label);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 9999px;
    margin-bottom: 1.25rem;
  }

  .senat-hero__title {
    font-family: var(--theme-font-family-headline);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 800;
    color: var(--camp-cream);
    line-height: 1.15;
    margin: 0 0 1.25rem;
  }

  .senat-hero__desc {
    font-family: var(--theme-font-family-sans);
    font-size: 1.0625rem;
    color: var(--camp-broskev);
    line-height: 1.7;
    max-width: 28rem;
    margin: 0 0 2rem;
    opacity: 0.9;
  }

  .senat-hero__btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--camp-gold);
    color: var(--camp-dark);
    font-family: var(--theme-font-family-label);
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 0.75rem 1.75rem;
    border-radius: var(--theme-button-border-radius);
    text-decoration: none;
    transition: background var(--theme-transition), transform var(--theme-transition);
  }

  .btn-primary:hover {
    background: #f0ca6b;
    transform: translateY(-1px);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--camp-cream);
    font-family: var(--theme-font-family-label);
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.75rem 1.75rem;
    border-radius: var(--theme-button-border-radius);
    border: 2px solid rgba(255, 248, 245, 0.35);
    text-decoration: none;
    transition: border-color var(--theme-transition), background var(--theme-transition), transform var(--theme-transition);
  }

  .btn-outline:hover {
    border-color: var(--camp-gold);
    color: var(--camp-gold);
    background: rgba(227, 183, 84, 0.08);
    transform: translateY(-1px);
  }

  .senat-hero__visual {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .hero-stack {
    position: relative;
    width: 100%;
    max-width: 450px;
    height: clamp(34rem, 46vw, 42rem);
  }

  .hero-stack__card {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    text-decoration: none;
    color: inherit;
    border-radius: calc(var(--theme-card-radius) + 0.25rem);
    overflow: hidden;
    border: 1px solid rgba(255, 248, 245, 0.14);
    background: linear-gradient(180deg, rgba(255, 248, 245, 0.04), rgba(255, 248, 245, 0.08));
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.42);
    opacity: 0;
    transform: translate(0, 0.75rem) rotate(0deg) scale(0.96);
    transition: transform 0.65s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.45s ease, box-shadow 0.45s ease;
    pointer-events: none;
    transform-origin: center center;
  }

  .hero-stack__card[data-state='active'] {
    opacity: 1;
    transform: translate(0, 0) rotate(0deg) scale(1);
    z-index: 3;
    pointer-events: auto;
    background: linear-gradient(180deg, rgba(255, 248, 245, 0.1), rgba(255, 248, 245, 0.16));
    border-color: rgba(255, 248, 245, 0.24);
  }

  .hero-stack__card[data-state='next'] {
    opacity: 0.92;
    transform: translate(1.3rem, 1.15rem) rotate(var(--stack-angle)) scale(0.95);
    z-index: 2;
    pointer-events: auto;
  }

  .hero-stack__card[data-state='hidden'] {
    opacity: 0;
    transform: translate(0.3rem, 1.8rem) rotate(calc(var(--stack-angle) * 1.2)) scale(0.9);
    z-index: 1;
  }

  .hero-stack__card:hover[data-state='active'] {
    box-shadow: 0 22px 64px rgba(0, 0, 0, 0.5);
  }

  .hero-stack__photo-wrap {
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .hero-stack__photo {
    width: 100%;
    height: 100%;
    min-height: 24rem;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.6s ease;
  }

  .hero-stack__card[data-state='active'] .hero-stack__photo {
    transform: scale(1.03);
  }

  .hero-stack__card[data-state='active'] .hero-stack__photo-gradient {
    background:
      linear-gradient(180deg, rgba(17, 12, 10, 0.01) 0%, rgba(17, 12, 10, 0.14) 46%, rgba(17, 12, 10, 0.92) 100%),
      linear-gradient(135deg, rgba(192, 57, 43, 0.24), transparent 42%);
  }

  .hero-stack__photo-gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(17, 12, 10, 0.02) 0%, rgba(17, 12, 10, 0.2) 48%, rgba(17, 12, 10, 0.86) 100%),
      linear-gradient(135deg, rgba(192, 57, 43, 0.2), transparent 42%);
  }

  .hero-stack__content {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1.35rem 1.4rem 1.5rem;
    background: linear-gradient(180deg, rgba(33, 24, 18, 0.88), rgba(17, 12, 10, 0.96));
  }

  .hero-stack__card[data-state='active'] .hero-stack__content {
    background: linear-gradient(180deg, rgba(33, 24, 18, 0.96), rgba(17, 12, 10, 0.995));
  }

  .hero-stack__obvod {
    font-family: var(--theme-font-family-label);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--camp-gold);
  }

  .hero-stack__name {
    font-family: var(--theme-font-family-headline);
    font-size: clamp(1.45rem, 2vw, 1.9rem);
    font-weight: 800;
    line-height: 1.05;
    color: var(--camp-cream);
  }

  .hero-stack__expertiza {
    font-family: var(--theme-font-family-sans);
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(255, 230, 213, 0.84);
  }

  .hero-stack__quote {
    font-family: var(--theme-font-family-serif);
    font-size: 0.95rem;
    line-height: 1.65;
    font-style: italic;
    color: var(--camp-broskev);
    margin: 0.3rem 0 0;
  }

  .hero-stack__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.75rem;
    font-family: var(--theme-font-family-label);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--camp-gold);
  }

  .hero-dots {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }

  .hero-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 248, 245, 0.2);
    cursor: pointer;
    padding: 0;
    transition: background var(--theme-transition), transform var(--theme-transition);
  }

  .hero-dot--active {
    background: var(--camp-gold);
    transform: scale(1.3);
  }

  @media (max-width: 900px) {
    .senat-hero__inner {
      grid-template-columns: 1fr;
      min-height: unset;
      gap: 2rem;
    }

    .senat-hero__visual {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .senat-hero__claim {
      padding: 2rem 0 1.5rem;
    }

    .senat-hero {
      padding-inline: 1.5rem;
      min-height: unset;
    }

    .hero-stack {
      height: 500px;
    }

    .hero-stack__card[data-state='next'] {
      transform: translate(0.75rem, 0.9rem) rotate(var(--stack-angle)) scale(0.95);
    }
  }

  @media (max-width: 520px) {
    .hero-stack {
      height: 450px;
    }

    .hero-stack__photo {
      min-height: 19rem;
    }

    .hero-stack__content {
      padding: 1.1rem 1.1rem 1.2rem;
    }
  }
</style>
