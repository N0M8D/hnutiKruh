    cil: 'Spravedlivý a udržitelný rozvoj regionů s důrazem na spolupráci a solidaritu.',
    navrhy: [
      { title: 'Přerozdělení daní pro regiony', desc: 'Změníme rozpočtové určení daní ve prospěch chudších regionů a rodin s dětmi.' },
      { title: 'Spolupráce obcí', desc: 'Podpoříme společenství obcí a sdílení služeb, aby se snížily náklady a zvýšila kvalita.' },
      { title: 'Dopravní dostupnost regionů', desc: 'Motivujeme k soukromým investicím a zlepšíme dopravní dostupnost regionů.' },
      { title: 'Nižší daně v chudších regionech', desc: 'Snížíme daně pro nízkopříjmové pracovníky a malé podnikatele v chudších regionech.' },
      { title: 'Vzdělávání v každém okrese', desc: 'Podpoříme kvalitní vzdělávání v každém okrese, včetně školních psychologů.' },
      { title: 'Oddlužení a šedá ekonomika', desc: 'Zlepšíme podmínky oddlužení a omezíme šedou ekonomiku.' },
      { title: 'Dostupné nájemní bydlení', desc: 'Rozvíjíme dostupné nájemní bydlení, aby skončil obchod s chudobou.' },
      { title: 'Strategický regionální rozvoj', desc: 'Posílíme plánování a strategii regionálního rozvoje na úrovni státu i obcí.' },
