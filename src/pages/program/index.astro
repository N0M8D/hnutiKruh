</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const navItems = document.querySelectorAll<HTMLButtonElement>('.program-nav__item');
    const panels = document.querySelectorAll<HTMLElement>('.program-panel');

    navItems.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.topic;

        navItems.forEach(b => b.classList.remove('is-active'));
        panels.forEach(p => p.classList.remove('is-active'));

        btn.classList.add('is-active');
        const panel = document.querySelector<HTMLElement>(`.program-panel[data-panel="${target}"]`);
        if (panel) panel.classList.add('is-active');
      });
    });
  });
</script>